# API keys for the OCR providers. Only fill in the ones you'll actually use.
#
# Setup:
#   1. Get keys from the providers you want to use:
#        - DashScope (Qwen):    https://dashscope.console.aliyun.com/apiKey
#        - Volcano Ark:         https://www.volcengine.com/product/ark  (create an API key in the console)
#        - Unisound (云知声):   https://www.hivoice.cn/  (U1 OCR / MaaS)
#   2. Copy this file to the INSTALLED skill location (NOT the source repo):
#        cp ocr-parser/.env.example ~/.claude/skills/ocr-parser/.env
#   3. Edit ~/.claude/skills/ocr-parser/.env and paste in the keys.
#
# The script auto-loads this file at call time. Missing keys produce a clear
# error at call time (e.g. "error: VOLCANO_API_KEY is not set").
#
# NEVER commit a real .env. Real .env files are gitignored; this .env.example
# is the only file with these names that gets committed.

# --- Alibaba DashScope (Qwen VL OCR) ---
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# --- Volcano Engine Ark (火山方舟, Doubao vision) ---
VOLCANO_API_KEY=your-volcano-ark-key-here

# --- Unisound (云知声) U1 OCR ---
UNISOUND_API_KEY=your-unisound-key-here
# Optional: override the API base (default https://maas-api.hivoice.cn)
# UNISOUND_BASE_URL=https://maas-api.hivoice.cn
# Optional: override the model (default u1-ocr)
# UNISOUND_MODEL=u1-ocr
