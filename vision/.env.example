# DashScope (Qwen-VL) API key — required by the vision skill.
#
# How to use this file:
#   1. Get a key: https://dashscope.console.aliyun.com/apiKey
#   2. Copy this file to ONE of these locations (the script checks them in order;
#      existing env vars take precedence over .env values):
#        - ./.env                          (project-local, useful for testing)
#        - ~/.claude/.env                  (global Claude config — recommended)
#        - set in Windows User Environment Variables
#   3. Replace the placeholder below with your real key.
#
# NEVER commit a real .env file. This .env.example is committed as a template;
# real .env files are matched by .gitignore at the repo root.
DASHSCOPE_API_KEY=sk-your-key-here

# Optional: override the model. Default: qwen-vl-max
# VISION_MODEL=qwen-vl-max
